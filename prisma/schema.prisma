generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id          String   @id @default(cuid())
  tmdbId      Int      @unique
  title       String
  overview    String?
  posterPath  String?
  backdropPath String?
  releaseDate String?
  rating      Float?
  createdAt   DateTime @default(now())
}